# ============================================================
# 환경 변수 예시 (비밀/키 제거 후 GitHub 업로드용)
# ============================================================
# 사용법:
# 1. 이 파일을 복사해서 .env 또는 시스템 환경 변수로 설정
# 2. .env 를 쓸 경우 프로젝트 루트에 두고, 실행 전에 로드
#    (IDE Run Configuration에서 EnvFile 플러그인 또는 수동 export)
# 3. 실제 값은 여기에 적지 말고, 로컬에서만 설정
# ============================================================

# DB (MySQL)
DB_USERNAME=root
DB_PASSWORD=your-db-password

# TMDB API (https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your-tmdb-api-key
# Bearer 토큰 (일부 API용, 없으면 비워둬도 됨)
TMDB_ACCESS_TOKEN=

# Kakao OAuth (https://developers.kakao.com 콘솔)
# 앱에서는 아래 long-form 이름만 사용 (Circular reference 방지)
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_KAKAO_CLIENT_ID=your-kakao-client-id
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_KAKAO_CLIENT_SECRET=your-kakao-client-secret
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_KAKAO_REDIRECT_URI=http://localhost:3000/login/oauth2/code/kakao

# JWT 서명용 시크릿 (32자 이상). Heroku는 APP_JWT_SECRET / APP_AES_SECRET 사용 (Circular reference 방지)
JWT_SECRET=your-jwt-secret-at-least-32-chars
# APP_JWT_SECRET=your-jwt-secret-at-least-32-chars

# AES 암호화용 시크릿 (app-api만 사용)
AES_SECRET=your-aes-secret
# APP_AES_SECRET=your-aes-secret

# 한국관광공사 공공데이터 API — 동일 키로 Odii(오디오 가이드)·EngService2(영문 관광) 등
# 여러 B551011 서비스에 활용 신청·승인이 필요할 수 있음. 키는 채팅/레포에 넣지 말고 Heroku ConfigVars 등만 사용.
VISITKOREA_SERVICE_KEY=your-visitkorea-service-key

# 공공데이터포털 api.odcloud.kr — 한국관광공사 여행기사목록(15121757)
# Heroku: ODCLOUD_SERVICE_KEY 로 설정. 레포/채팅에 실제 키를 넣지 마세요.
ODCLOUD_SERVICE_KEY=your-odcloud-service-key

# 한국관광공사 비대면 안심관광지 목록 (publicDataPk 15105715, odcloud)
# End Point = api.odcloud.kr/api/{pk}/v1/uddi:{id} — serviceKey는 ODCLOUD_SERVICE_KEY 로 별도 전달
ODCLOUD_SAFE_TOURISM_LIST_URL=https://api.odcloud.kr/api/15105715/v1/uddi:2843667c-8f62-4ef8-9c39-e9e1dbdf1f1a
